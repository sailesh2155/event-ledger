<?xml version="1.0" encoding="UTF-8"?>
<!--
  JSON structured logging (spec requirement: trace ID, timestamp, level,
  service name in structured output). LogstashEncoder emits one JSON object
  per line including @timestamp, level, logger, thread, message and ALL MDC
  entries - which is how the traceId set by TraceIdFilter appears in every
  line automatically.
-->
<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name"/>

    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"${serviceName}"}</customFields>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
    </root>
</configuration>
